# Healthcare Drips Environment Configuration

# Network Configuration
NETWORK=localhost
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337

# Wallet Configuration
PRIVATE_KEY=your_private_key_here
MNEMONIC=test test test test test test test test junk

# Contract Addresses (will be populated after deployment)
HEALTHCARE_DRIPS_CONTRACT=0x...
CONTRIBUTOR_TOKEN_CONTRACT=0x...

# API Keys
INFURA_API_KEY=your_infura_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key

# Frontend Configuration
REACT_APP_NETWORK=http://127.0.0.1:8545
REACT_APP_CONTRACT_ADDRESS=0x...

# Development
NODE_ENV=development
LOG_LEVEL=debug

# Security
ENABLE_HARDHAT_MEMORY=true
GAS_LIMIT=8000000
GAS_PRICE=20000000000

# Testing
TEST_TIMEOUT=60000
COVERAGE_THRESHOLD=80
