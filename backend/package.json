{
  "name": "healthcare-backend",
  "version": "1.0.0",
  "description": "Backend API for Healthcare Patient Dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:contract": "jest --testPathPattern=contract.test.js --verbose",
    "test:performance": "jest --testPathPattern=performance.test.js --verbose --testTimeout=30000",
    "test:chaos": "jest --testPathPattern=chaos.test.js --verbose",
    "test:report": "jest --coverage --reporters=default --reporters=jest-html-reporter",
    "test:ci": "jest --coverage --ci --forceExit --reporters=default --reporters=jest-html-reporter"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "socket.io": "^4.7.2",
    "sqlite3": "^5.1.6",
    "redis": "^4.6.7",
    "node-cache": "^5.1.2",
    "axios": "^1.5.0",
    "moment": "^2.29.4",
    "uuid": "^9.0.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "crypto": "^1.0.1",
    "stellar-sdk": "^11.3.0",
    "soroban-client": "^20.0.0",
    "web3": "^1.10.0",
    "ethers": "^6.7.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "supertest": "^6.3.3",
    "jest-html-reporter": "^3.10.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000,
    "forceExit": true,
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    },
    "collectCoverageFrom": [
      "routes/**/*.js",
      "services/**/*.js",
      "middleware/**/*.js",
      "!services/logger.js",
      "!services/aiOracleService.js"
    ],
    "reporters": [
      "default",
      ["jest-html-reporter", {
        "pageTitle": "Healthcare Insurance Test Report",
        "outputPath": "test-report/index.html",
        "includeFailureMsg": true,
        "includeSuiteFailure": true
      }]
    ]
  },
  "keywords": [
    "healthcare",
    "api",
    "patient-dashboard",
    "medical-records",
    "premium-adjustment",
    "ai-driven",
    "insurance"
  ],
  "author": "Healthcare Team",
  "license": "MIT"
}
